<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_search_skeu_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="★ Suscripciones"
        android:textColor="#FFF8F8F8"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subscriptions_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="No tienes canales suscritos todavía."
        android:textColor="#FFE2E2E2"
        android:textSize="14sp"
        android:visibility="gone" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/subscriptions_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/subscriptions_close_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/search_button_skeu_light"
            android:backgroundTint="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Cerrar"
            android:textColor="#FF222222"
            android:textSize="13sp" />
    </LinearLayout>

</LinearLayout>
