<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_search_skeu_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Búsqueda avanzada"
        android:textColor="#FFF8F8F8"
        android:textSize="18sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/advanced_search_edit_text"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/search_input_skeu"
        android:hint="Qué quieres buscar... (opcional)"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:singleLine="true"
        android:textColor="#FF1D1D1D"
        android:textColorHint="#FF6C6C6C" />

    <!-- Filters Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Fecha de subida:"
        android:textColor="#FFE9E9E9"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/advanced_spinner_date"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:background="#FFFFFF" 
        android:spinnerMode="dropdown" />
<!-- Note: colorSurface or standard styling. Since app is custom, standard Spinner might look odd. 
     But let's trust default or set a standard background if needed.
     Actually, better to use standard system Spinner style for API 16 compatibility. -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Duración:"
        android:textColor="#FFE9E9E9"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/advanced_spinner_duration"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:spinnerMode="dropdown" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Ordenar por:"
        android:textColor="#FFE9E9E9"
        android:textSize="14sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/advanced_spinner_sort"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="4dp"
        android:spinnerMode="dropdown" />

    <!-- Search Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/advanced_cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/search_button_skeu_light"
            android:backgroundTint="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Cancelar"
            android:textColor="#FF222222"
            android:textSize="13sp"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/advanced_go_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/search_button_skeu_light"
            android:backgroundTint="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Buscar"
            android:textColor="#FF222222"
            android:textSize="13sp"
            app:backgroundTint="@null" />
    </LinearLayout>

</LinearLayout>
