<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#FFFBFBFB"
                        android:endColor="#FFE7E7E7" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF7D9BB6" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="22dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#66FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="7dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#FFF4F4F4"
                        android:endColor="#FFD9D9D9" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF8D8D8D" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="22dp">
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#66FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
