<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF1E1E1E"
                android:centerColor="#FF080808"
                android:endColor="#FF000000" />
            <stroke
                android:width="1dp"
                android:color="#FF444444" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="17dp" />
            <stroke
                android:width="1dp"
                android:color="#33000000" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="28dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:angle="270"
                android:startColor="#30FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
