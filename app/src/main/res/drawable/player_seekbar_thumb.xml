<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Shadow/Edge -->
    <item>
        <shape android:shape="oval">
            <size android:width="20dp" android:height="20dp" />
            <solid android:color="#FF888888" />
        </shape>
    </item>
    <!-- Main Knob -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFFFF" />
            <stroke android:width="1dp" android:color="#FFD0D0D0" />
        </shape>
    </item>
    <!-- Center Dot/Detail -->
    <item android:left="7dp" android:top="7dp" android:right="7dp" android:bottom="7dp">
        <shape android:shape="oval">
            <solid android:color="#FFBBBBBB" />
        </shape>
    </item>
</layer-list>
