<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF7D0000"
                android:endColor="#FFB40000" />
            <stroke
                android:width="1dp"
                android:color="#FFCE4C4C" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFBE0000"
                android:centerColor="#FFA80000"
                android:endColor="#FF930000" />
            <stroke
                android:width="1dp"
                android:color="#FFD26868" />
        </shape>
    </item>
</selector>
