<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="3dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF2AA74F"
                android:centerColor="#FF1A8F42"
                android:endColor="#FF117337" />
            <stroke
                android:width="1dp"
                android:color="#FF0A5A2A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="3dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF5EE58C"
                android:centerColor="#FF30C568"
                android:endColor="#FF169F4D" />
            <stroke
                android:width="1dp"
                android:color="#FF0E6B33" />
        </shape>
    </item>
</selector>
