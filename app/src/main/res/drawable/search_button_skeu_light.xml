<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#FF9D9D9D"
                        android:endColor="#FFC2C2C2" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF686868" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="5dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#22000000" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="6dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#FFE0E0E0"
                        android:centerColor="#FFD0D0D0"
                        android:endColor="#FFBDBDBD" />
                    <stroke
                        android:width="1dp"
                        android:color="#FF777777" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="18dp">
                <shape android:shape="rectangle">
                    <corners android:radius="5dp" />
                    <gradient
                        android:angle="270"
                        android:startColor="#50FFFFFF"
                        android:endColor="#00FFFFFF" />
                </shape>
            </item>
            <item
                android:left="1dp"
                android:top="1dp"
                android:right="1dp"
                android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="5dp" />
                    <stroke
                        android:width="1dp"
                        android:color="#22000000" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
