<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_search_skeu_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Opciones"
        android:textColor="#FFF8F8F8"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/legacy_menu_settings_button"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/search_button_skeu_light"
        android:backgroundTint="@null"
        android:text="Ajustes"
        android:textColor="#FF222222"
        android:textSize="14sp" />

    <Button
        android:id="@+id/legacy_menu_subscriptions_button"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/search_button_skeu_light"
        android:backgroundTint="@null"
        android:text="★ Suscripciones"
        android:textColor="#FF222222"
        android:textSize="14sp" />

    <Button
        android:id="@+id/legacy_menu_search_button"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/search_button_skeu_light"
        android:backgroundTint="@null"
        android:text="Buscar"
        android:textColor="#FF222222"
        android:textSize="14sp" />
</LinearLayout>
