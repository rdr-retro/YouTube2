<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/dialog_search_skeu_background"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ajustes"
        android:textColor="#FFF8F8F8"
        android:textSize="18sp"
        android:textStyle="bold" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/settings_hide_shorts_switch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Ocultar shorts"
        android:textColor="#FFEFEFEF"
        android:textSize="15sp"
        app:trackTint="#FF8F8F8F" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/settings_cancel_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/search_button_skeu_light"
            android:backgroundTint="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Cancelar"
            android:textColor="#FF222222"
            android:textSize="13sp" />

        <Button
            android:id="@+id/settings_save_button"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/search_button_skeu_light"
            android:backgroundTint="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="Guardar"
            android:textColor="#FF222222"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
