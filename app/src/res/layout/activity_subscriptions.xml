<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <Button
            android:id="@+id/subscriptions_back_button"
            android:layout_width="78dp"
            android:layout_height="34dp"
            android:background="@drawable/search_button_skeu_light"
            android:backgroundTint="@null"
            android:text="Volver"
            android:textAllCaps="false"
            android:textColor="#FF222222"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="★ Suscripciones"
            android:textColor="#FFF6F6F6"
            android:textSize="19sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="78dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/subscriptions_screen_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:text="No tienes canales suscritos."
        android:textColor="#FFC9C9C9"
        android:textSize="15sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/subscriptions_screen_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1"
        android:background="@android:color/black"
        android:scrollbars="vertical" />

</LinearLayout>
