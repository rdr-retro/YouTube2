<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/detail_header_bar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@drawable/header_gradient">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/detail_guideline_start"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.01" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/detail_guideline_end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_end="7dp" />

        <FrameLayout
            android:id="@+id/detail_header_logo_container"
            android:layout_width="106dp"
            android:layout_height="53dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@id/detail_guideline_start"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.0">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/detail_header_logo"
                android:layout_width="106dp"
                android:layout_height="53dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/app_name"
                app:srcCompat="@drawable/youtube" />

            <TextView
                android:id="@+id/detail_header_logo_suffix"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:rotation="16"
                android:text="2"
                android:textColor="#FFF2F2F2"
                android:textSize="20sp"
                android:textStyle="bold" />

        </FrameLayout>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/detail_header_edit"
            android:layout_width="@dimen/header_icon_size"
            android:layout_height="@dimen/header_icon_size"
            android:layout_marginEnd="8dp"
            android:layout_marginRight="8dp"
            android:contentDescription="Compartir video"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/detail_guideline_end"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_share_video"
            app:tint="@color/icon_tint" />

        <View
            android:id="@+id/detail_header_separator"
            android:layout_width="1dp"
            android:layout_height="@dimen/header_separator_height"
            android:layout_marginEnd="@dimen/header_separator_margin"
            android:background="#80FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/detail_header_edit"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/detail_header_search"
            android:layout_width="@dimen/header_icon_size"
            android:layout_height="@dimen/header_icon_size"
            android:layout_marginEnd="@dimen/header_separator_margin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/detail_header_separator"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_search"
            app:tint="@color/icon_tint" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:id="@+id/detail_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/detail_content_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/detail_player_container"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:background="@android:color/black">

                <com.google.android.exoplayer2.ui.PlayerView
                    android:id="@+id/detail_player_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/black"
                    app:resize_mode="fit"
                    app:show_timeout="3000"
                    app:use_controller="false" />

                <FrameLayout
                    android:id="@+id/detail_player_controls"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Centered Play/Pause/Loop Controls -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/detail_control_play_pause"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Play/Pause"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_player_pause"
                            app:tint="#FFFFFFFF" />

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/detail_control_loop"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginStart="32dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Loop"
                            android:padding="8dp"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_player_loop"
                            app:tint="#FFFFFFFF" />
                    </LinearLayout>

                    <!-- Bottom Seekbar Controls -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:background="@drawable/player_controls_scrim"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingTop="14dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:id="@+id/detail_control_current_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textColor="#FFFFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <SeekBar
                            android:id="@+id/detail_control_seekbar"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:background="@null"
                            android:max="1000"
                            android:maxHeight="1dp"
                            android:minHeight="1dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:progressDrawable="@drawable/player_seekbar_progress"
                            android:splitTrack="false"
                            android:thumb="@drawable/player_seekbar_thumb"
                            android:thumbOffset="12dp" />

                        <TextView
                            android:id="@+id/detail_control_total_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="0:00"
                            android:textColor="#FFFFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone" />

                        <androidx.appcompat.widget.AppCompatImageButton
                            android:id="@+id/detail_control_fullscreen"
                            android:layout_width="wrap_content"
                            android:layout_height="41dp"
                            android:layout_marginStart="8dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Pantalla completa"
                            android:padding="3dp"
                            android:scaleType="centerInside"
                            app:srcCompat="@drawable/ic_player_fullscreen_enter"
                            app:tint="#FFFFFFFF" />
                    </LinearLayout>
                </FrameLayout>

                <ProgressBar
                    android:id="@+id/detail_player_loading"
                    style="?android:attr/progressBarStyleLarge"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:indeterminate="true"
                    android:visibility="gone" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/detail_tabs_container"
                android:layout_width="match_parent"
                android:layout_height="49dp"
                android:background="#FF080808">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tab_info"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/tab_info_selected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Info"
                        android:textColor="#FFF2F2F2"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tab_related"
                        android:layout_width="0dp"
                        android:layout_height="47dp"
                        android:layout_gravity="top"
                        android:layout_weight="1"
                        android:background="@drawable/tab_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Related"
                        android:textColor="#FFB8B8B8"
                        android:textSize="14sp" />

                    <View
                        android:id="@+id/tab_separator_related_comments"
                        android:layout_width="1dp"
                        android:layout_height="47dp"
                        android:layout_gravity="top"
                        android:background="#33FFFFFF" />

                    <TextView
                        android:id="@+id/tab_comments"
                        android:layout_width="0dp"
                        android:layout_height="47dp"
                        android:layout_gravity="top"
                        android:layout_weight="1"
                        android:background="@drawable/tab_unselected"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Comments"
                        android:textColor="#FF8D8D8D"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:id="@+id/tab_top_line"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_gravity="top"
                    android:background="#99FFFFFF" />

                <View
                    android:id="@+id/tab_bottom_line"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_gravity="bottom"
                    android:background="#FFFFFFFF" />

                <View
                    android:id="@+id/tab_bottom_mask"
                    android:layout_width="1dp"
                    android:layout_height="2dp"
                    android:layout_gravity="bottom|left"
                    android:background="#FF000000" />
            </FrameLayout>

            <!-- Info tab content -->
            <LinearLayout
                android:id="@+id/detail_info_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/detail_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFF0F0F0"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/detail_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text=""
                    android:textColor="#FFBFBFBF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/detail_stats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text=""
                    android:textColor="#FFE2E2E2"
                    android:textSize="14sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#33FFFFFF" />

                <TextView
                    android:id="@+id/detail_channel_section"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text=""
                    android:textColor="#FFCFCFCF"
                    android:textSize="13sp" />

                <LinearLayout
                    android:id="@+id/detail_channel_buttons_row"
                    android:layout_width="124dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/detail_channel_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/channel_button_old"
                        android:backgroundTint="@null"
                        android:ellipsize="end"
                        android:gravity="start|center_vertical"
                        android:maxLines="1"
                        android:minHeight="18dp"
                        android:paddingStart="5dp"
                        android:paddingTop="1dp"
                        android:paddingEnd="5dp"
                        android:paddingBottom="1dp"
                        android:text=""
                        android:textAllCaps="false"
                        android:textColor="#FF222222"
                        android:textSize="10sp" />

                    <androidx.appcompat.widget.AppCompatImageButton
                        android:id="@+id/detail_channel_arrow_button"
                        android:layout_width="27dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/channel_arrow_button_green"
                        android:backgroundTint="@null"
                        android:contentDescription="Opciones del canal"
                        android:padding="0dp"
                        android:scaleType="center"
                        app:srcCompat="@drawable/ic_channel_arrow_down" />
                </LinearLayout>

                <TextView
                    android:id="@+id/detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:autoLink="web"
                    android:linksClickable="true"
                    android:text=""
                    android:textColor="#FFB9B9B9"
                    android:textColorLink="#33B5E5"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Related tab content -->
            <LinearLayout
                android:id="@+id/detail_related_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Related videos"
                    android:textColor="#FFF0F0F0"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Dynamic container for related videos -->
                <LinearLayout
                    android:id="@+id/detail_related_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />
            </LinearLayout>

            <!-- Comments tab content -->
            <LinearLayout
                android:id="@+id/detail_comments_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comments"
                    android:textColor="#FFF0F0F0"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Dynamic container for comments -->
                <LinearLayout
                    android:id="@+id/detail_comments_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>
