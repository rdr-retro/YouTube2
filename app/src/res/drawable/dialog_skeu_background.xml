<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF1E1E1E"
                android:centerColor="#FF111111"
                android:endColor="#FF070707" />
            <stroke
                android:width="1dp"
                android:color="#44FFFFFF" />
        </shape>
    </item>

    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <stroke
                android:width="1dp"
                android:color="#33000000" />
        </shape>
    </item>

    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="270"
                android:startColor="#26FFFFFF"
                android:endColor="#00000000" />
        </shape>
    </item>

</layer-list>
