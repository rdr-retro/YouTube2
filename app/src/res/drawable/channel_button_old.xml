<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFB4B4B4"
                android:endColor="#FFD3D3D3" />
            <stroke
                android:width="1dp"
                android:color="#FF7A7A7A" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="2dp" />
            <gradient
                android:angle="270"
                android:startColor="#FFE3E3E3"
                android:centerColor="#FFD6D6D6"
                android:endColor="#FFC2C2C2" />
            <stroke
                android:width="1dp"
                android:color="#FF7A7A7A" />
        </shape>
    </item>
</selector>
