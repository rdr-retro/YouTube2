<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <gradient
                android:angle="270"
                android:startColor="#FF4A4A4A"
                android:centerColor="#FF323232"
                android:endColor="#FF1F1F1F" />
            <stroke
                android:width="2dp"
                android:color="#CCFFFFFF" />
        </shape>
    </item>

    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="26dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <gradient
                android:angle="270"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

</layer-list>
